<Window x:Class="DownloadComics.windows.ArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DownloadComics.windows"
        xmlns:res="clr-namespace:DownloadComics.Extension"
        xmlns:m="clr-namespace:ComicsLib.Models;assembly=ComicsLib"
        mc:Ignorable="d"
        Title="{res:Loc Key=Title, Section=ArchiveWindow}" ResizeMode="NoResize"
        Height="600" Width="520" WindowStartupLocation="CenterOwner" Loaded="Window_Loaded"
        DataContext="{Binding ViewModel, RelativeSource={RelativeSource Self}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center"
                Margin="10">
            <Button Content="{Binding SearchBTNContent, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="16" 
                    Command="{Binding SearchCommand}" Padding="5,0,5,0"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Content="{res:Loc Key=RestoreBTN, Section=Buttons}" FontSize="16"
                    Margin="10,0,10,0" Command="{Binding RestoreCommand}" Padding="5,0,5,0"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Content="{Binding DeleteBTNContent, RelativeSource={RelativeSource AncestorType=local:ArchiveWindow}}"
                    FontSize="16" Padding="5,0,5,0"
                    Command="{Binding DeleteItemCommand}"/>
        </StackPanel>

        <TreeView x:Name="folderTree" Grid.Row="1" Margin="10"
                  ItemsSource="{Binding Items}"
                  SelectedItemChanged="FolderTree_SelectedItemChanged">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Name}"/>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</Window>
