<Window x:Class="DownloadComics.windows.Dialogs.SearchDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DownloadComics.windows.Dialogs"
        xmlns:res="clr-namespace:DownloadComics.Extension"
        mc:Ignorable="d"
        Title="{res:Loc Key=Title, Section=ScanDialog}" Height="250" Width="500" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" SizeToContent="WidthAndHeight"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">
  
    
    <Grid VerticalAlignment="Center" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical" 
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding MangaTXT, Mode=TwoWay}" FontSize="16"/>
            <TextBlock Text="{Binding BackupTXT, Mode=TwoWay}" FontSize="16"/>
            <TextBlock Text="{Binding JDTXT, Mode=TwoWay}" FontSize="16"/>
            <TextBlock Text="{Binding Question, Mode=TwoWay}" FontSize="16"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="{res:Loc Key=Yes, Section=Dialog}"
                    Margin="10,0,10,0" Padding="10,0,10,0" FontSize="16"
                    Click="AddBTN_Click"/>
            <Button Content="{res:Loc Key=No, Section=Dialog}"
                    Padding="10,0,10,0" FontSize="16" Click="CancelBTN_Click"/>
        </StackPanel>
    </Grid>
    
</Window>
