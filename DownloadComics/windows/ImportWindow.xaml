<Window x:Class="DownloadComics.windows.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DownloadComics.windows"
        xmlns:web="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:res="clr-namespace:DownloadComics.Extension"
        mc:Ignorable="d" WindowStartupLocation="CenterOwner"
        Title="{res:Loc Key=Title, Section=ImportWindow}"
        Height="900" Width="1500" Loaded="Window_Loaded"
        DataContext="{Binding ViewModel, RelativeSource={RelativeSource Self}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="177*"/>
            <RowDefinition Height="40*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        
        <Grid Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ComboBox Margin="10" FontSize="16" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" ItemsSource="{Binding Files}"
                      SelectedItem="{Binding SelectedFile, Mode=TwoWay}"/>
            <ListView Grid.Row="1" Margin="10"
                      ItemsSource="{Binding URLS}"
                      SelectedItem="{Binding Comic.BaseURL, Mode=TwoWay}"/>
        </Grid>

        <web:WebView2 x:Name="browser" Grid.Column="1" Margin="10"
                      Source="{Binding Comic.BaseURL}"/>

        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Margin="10" VerticalAlignment="Center">
                    <TextBlock Text="URL:" FontSize="16"/>
                    <TextBox Text="{Binding Comic.BaseURL, Mode=TwoWay}" Width="300" Height="30"
                             TextWrapping="NoWrap" FontSize="16" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="10">
                    <TextBlock Text="{res:Loc Key=Author, Section=Comic, Format='{}{0}:'}" FontSize="16"/>
                    <TextBox Text="{Binding Comic.Author, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="150" Height="30" TextWrapping="NoWrap" FontSize="16"
                             VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="10">
                    <TextBlock Text="{res:Loc Key=PackageName, Section=Comic, Format='{}{0}:'}"
                               FontSize="16"/>
                    <TextBox Text="{Binding Comic.PackageName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="150" Height="30" TextWrapping="NoWrap" FontSize="16" 
                             VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="10">
                    <TextBlock Text="{res:Loc Key=Pages, Section=Comic, Format='{}{0}:'}" FontSize="16"/>
                    <TextBox Text="{Binding Comic.NumberPages, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Width="75" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="10,10,10,12" 
                        HorizontalAlignment="Center" VerticalAlignment="Top">
                <Button Content="{Binding AddBTNContent, RelativeSource={RelativeSource AncestorType=local:ImportWindow}}"
                        Margin="10,0,10,0" Padding="10,0,10,0" Height="30" FontSize="16"
                        Command="{Binding AddComicCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                <Button Content="{Binding SearchBTNContent, RelativeSource={RelativeSource AncestorType=local:ImportWindow}}" 
                        Margin="10,0,10,0" Padding="10,0,10,0" Height="30" FontSize="16"
                        Command="{Binding SearchComicCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                <Button Content="{Binding ClearBTNContent, RelativeSource={RelativeSource AncestorType=local:ImportWindow}}"
                        Margin="10,0,0,0" Padding="10,0,10,0" Height="30" FontSize="16"
                        Command="{Binding ResetComicCommand}"/>
            </StackPanel>
         </StackPanel>
    </Grid>
</Window>
