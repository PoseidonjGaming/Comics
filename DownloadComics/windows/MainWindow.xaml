<Window x:Class="DownloadComics.windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:res="clr-namespace:DownloadComics.Extension"
        xmlns:vw="clr-namespace:ComicsInfraLib.Models.Views;assembly=ComicsInfraLib"
        xmlns:local="clr-namespace:DownloadComics.windows"
        mc:Ignorable="d"
        FontSize="14" Height="900" Width="1400" Title="{res:Loc Key=Title, Section=MainWindow}"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize" Closing="Window_Closing"
        DataContext="{Binding ViewModel, RelativeSource={RelativeSource Self}}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="415"/>
            <ColumnDefinition Width="673*"/>
        </Grid.ColumnDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="2" VerticalAlignment="Top">
            <MenuItem Header="{res:Loc Key=Add, Section=MainWindow}" FontSize="14">
                <MenuItem Header="{res:Loc Key=AddLink, Section=MainWindow}" 
                          FontSize="14" Click="AddItem_Click"/>
                <MenuItem Header="{res:Loc Key=ImportLinks, Section=MainWindow}" 
                          FontSize="14" Click="ImportLinksItem_Click"/>
            </MenuItem>
            <MenuItem Header="{res:Loc Key=Send, Section=MainWindow}" 
                      FontSize="14" Click="SendItem_Click"/>
            <MenuItem Header="{res:Loc Key=Archive, Section=MainWindow}" FontSize="14"
                      Click="ArchiveItem_Click"/>
            <MenuItem Header="{res:Loc Key=Settings, Section=MainWindow}" FontSize="14">
                <MenuItem Header="{res:Loc Key=OpenSettings, Section=MainWindow}"
                          Click="OpenSettingsItem_Click" FontSize="14"/>
                <MenuItem Header="{res:Loc Key=OpenJDownloaderSettings, Section=MainWindow}" 
                          FontSize="14" Click="CredentialsItem_Click"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Margin="10,10,0,10" FontSize="16" TextChanged="FilterTXT_TextChanged"/>
            <ComboBox Grid.Column="1" Margin="10" HorizontalAlignment="Stretch"
                      ItemsSource="{Binding Hosts}"
                      SelectedItem="{Binding SelectedHost, Mode=TwoWay}"
                      SelectionChanged="Hosts_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource HostConverter}}"
                                   FontSize="16"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <ListView Grid.Row="1" Grid.ColumnSpan="2" Margin="10,0,10,10" 
                     ItemsSource="{Binding Comics, Mode=TwoWay}"
                     SelectedItem="{Binding SelectedComic, Mode=TwoWay}"
                     DisplayMemberPath="PackageName"/>
        </Grid>

        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Margin="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Vertical" Margin="0,0,20,0">
                    <TextBlock Text="URL:" FontSize="16"/>
                    <TextBox Text="{Binding SelectedComic.URL, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Width="750" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{res:Loc Key=Host, Section=Comic,Format='{}{0}:'}" FontSize="16"/>
                    <TextBox FontSize="16" Width="150"
                             Text="{Binding SelectedComic.URL, Converter={StaticResource HostConverter}}"/>
                </StackPanel>            
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,10,0,0">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{res:Loc Key=Author, Section=Comic,Format='{}{0}:'}" FontSize="16"/>
                    <TextBox Text="{Binding SelectedComic.Author, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="150" TextWrapping="NoWrap"/>
                </StackPanel>
                <StackPanel Orientation="Vertical"  Margin="20,0,20,0">
                    <TextBlock Text="{res:Loc Key=PackageName, Section=Comic,Format='{}{0}:'}"
                               FontSize="16" TextWrapping="NoWrap"/>
                    <TextBox FontSize="16" Width="300"
                             Text="{Binding SelectedComic.PackageName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{res:Loc Key=Filename, Section=Comic, Format='{}{0}:'}" FontSize="16"/>
                    <TextBox Text="{Binding SelectedComic.Filename, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Width="250" TextWrapping="NoWrap"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <TextBlock Text="{res:Loc Key=Path, Section=Comic, Format='{}{0}:'}" FontSize="16"/>
                <TextBox Text="{Binding SelectedComic.Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="16" Width="700" TextWrapping="NoWrap" HorizontalAlignment="Left"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{res:Loc Key=Pages, Section=Comic, Format='{}{0}:'}"
                               FontSize="16"/>
                    <TextBox Text="{Binding SelectedComic.NumberPages, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Width="75" TextWrapping="NoWrap" HorizontalAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="20,0,20,0">
                    <TextBlock Text="{res:Loc Key=Enable, Section=Comic,Format='{}{0}:'}" FontSize="16"/>
                    <CheckBox IsChecked="{Binding SelectedComic.Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Content="{res:Loc Key=ChangeSourceBTN, Section=Buttons}"
                        FontSize="16" Padding="5" Command="{Binding ChangeSourceCommand}"/>
                <Button Content="{res:Loc Key=UnselectBTN, Section=Buttons}"
                        FontSize="16" Padding="5" Margin="10,0,10,0" Command="{Binding UnselectCommand}"/>
                <Button Content="{Binding DeleteBTNContent, RelativeSource={RelativeSource AncestorType=local:MainWindow}}"
                        FontSize="16" Padding="5" Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
