<Window x:Class="DownloadComics.windows.PathWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DownloadComics.windows"
        xmlns:res="clr-namespace:DownloadComics.Extension"
        mc:Ignorable="d"
        Title="PathWindow" Height="600" Width="800" Loaded="Window_Loaded" Unloaded="Window_Unloaded"
        DataContext="{Binding ViewModel, RelativeSource={RelativeSource Self}}" WindowStartupLocation="CenterOwner">
    
    <Grid HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <TextBlock Text="{res:Loc Key=Path, Section=Comic, Format='{}{0}:'}" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="rootCMB" Width="275" FontSize="16"
                      ItemsSource="{Binding Roots}"
                      SelectedItem="{Binding SelectedRoot, Mode=TwoWay}"/>
            <TextBox x:Name="pathTXT" Text="{Binding SelectedPath, Mode=TwoWay}" 
                     Width="400" Margin="10,0,0,0" FontSize="16" VerticalContentAlignment="Center"/>
        </StackPanel>

        <ListView Grid.Row="1" x:Name="pathLST" ItemsSource="{Binding Paths}"
          SelectedItem="{Binding SelectedPath, Mode=TwoWay}"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="{res:Loc Key=SelectBTN, Section=Buttons}" Margin="10" Padding="5,0,5,0"
                    FontSize="16" Command="{Binding SelectCommand}"/>
            <Button Grid.Column="1" Content="{res:Loc Key=CancelBTN, Section=Buttons}"
                    FontSize="16" Margin="0,10" Padding="5,0,5,0"
                    Command="{Binding CancelCommand}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
