<Window x:Class="DownloadComics.windows.Settings.AppSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DownloadComics.windows.Settings"
        xmlns:res="clr-namespace:DownloadComics.Extension"
        xmlns:ext="clr-namespace:DownloadComics.Extension"
        mc:Ignorable="d" Closed="Window_Closed"
        Title="{res:Loc Key=Title, Section=SettingsWindow}"
        Height="450" Width="600" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        DataContext="{Binding ViewModel, RelativeSource={RelativeSource Self}}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Menu>
            <MenuItem Header="Comic" FontSize="14" Click="ComicItem_Click"/>
            <MenuItem Header="{res:Loc Key=Hosts, Section=SettingsWindow}" FontSize="14">
                <MenuItem Header="{res:Loc Key=SearchHosts, Section=SettingsWindow}"
                          FontSize="14" Click="HostsItem_Click"/>
                <MenuItem Header="{res:Loc Key=ConfirmHosts, Section=SettingsWindow}"
                          FontSize="14" Click="ConfirmHostsItem_Click"/>
                <MenuItem Header="{res:Loc Key=ExcludedHosts, Section=SettingsWindow}"
                          FontSize="14" Click="ExcludedHostsItem_Click"/>
            </MenuItem>
            <MenuItem Header="{res:Loc Key=Paths, Section=SettingsWindow}"
                      FontSize="14" Click="PathsItem_Click"/>
            <MenuItem Header="{res:Loc Key=ImportSettings, Section=SettingsWindow}"
                      FontSize="14" Click="ImportItem_Click"/>
            <MenuItem Header="{res:Loc Key=ExportSettings, Section=SettingsWindow}" 
                      FontSize="14" Click="ExportItem_Click"/>
        </Menu>
        
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{res:Loc Key=Path, Section=SettingsAppPage}"
                       FontSize="16" Margin="0,0,0,5"/>
                <TextBox Grid.Row="1" Text="{Binding InputModel.Path, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=Window}}" 
                     IsReadOnly="True" FontSize="16"/>
                <Button Grid.Row="1" Grid.Column="1"  Margin="10,0,10,0" FontSize="16" 
                        Content="{res:Loc Key=PathBTN, Section=Buttons}" 
                        Command="{Binding SetPathCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

            </Grid>
            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <TextBlock Text="Langage" FontSize="16"/>
                <ComboBox ItemsSource="{Binding Languages, Mode=TwoWay}"
                          SelectedItem="{Binding Lang, Mode=TwoWay}" 
                          SelectionChanged="Lang_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <Image Source="{ext:Image}" Width="28" Height="21" Margin="6,0,12,0"
                                       Stretch="UniformToFill" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DisplayName}" FontSize="16" 
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
