<Window x:Class="DownloadComics.windows.Settings.CollectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DownloadComics.windows.Settings"
        xmlns:res="clr-namespace:DownloadComics.Extension"
        mc:Ignorable="d"
        Title="CollectionSettingsWindow" Height="650" Width="550" WindowStartupLocation="CenterOwner"
        DataContext="{Binding ViewModel, RelativeSource={RelativeSource Self}}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="359*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <StackPanel Orientation="Vertical" Margin="10">
                <TextBlock Text="{Binding Label}" FontSize="16" VerticalAlignment="Center"
                           Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox FontSize="16" Width="200" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="{Binding AddBTNContent, RelativeSource={RelativeSource AncestorType=Window}}"
                            FontSize="16" Margin="10,0,10,0" Padding="5,0,5,0"
                            Command="{Binding AddValueCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="{Binding DeleteBTNContent, RelativeSource={RelativeSource AncestorType=Window}}" 
                            FontSize="16" Padding="5,0,5,0"
                            Command="{Binding DeleteValueCommand}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <ListView Grid.Row="1" Margin="10" ItemsSource="{Binding Collection, Mode=TwoWay}"
                  SelectedItem="{Binding SelectedHost, Mode=TwoWay}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource HostConverter}}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
