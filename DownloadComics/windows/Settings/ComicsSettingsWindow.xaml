<Window x:Class="DownloadComics.windows.Settings.SettingsComicsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DownloadComics.windows.Settings"
        xmlns:res="clr-namespace:DownloadComics.Extension"
        mc:Ignorable="d"
        Title="{res:Loc Key=Title, Section=SettingsComicWindow}" Height="450" Width="900" WindowStartupLocation="CenterOwner"
        DataContext="{Binding ViewModel, RelativeSource={RelativeSource Self}}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Vertical" Margin="10">
                <TextBlock Text="{res:Loc Key=BaseURL, Section=Comic, Format='{}{0}:'}" 
                           FontSize="16" HorizontalAlignment="Left" Margin="0,0,0,5"/>
                <TextBox FontSize="16" TextWrapping="NoWrap"
                         Text="{Binding Comic.BaseURL, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="URL:" FontSize="16" Margin="0,0,0,5" HorizontalAlignment="Left"/>
                    <TextBox FontSize="16" TextWrapping="NoWrap" Width="600"
                             Text="{Binding Comic.URL, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="10,0,0,0">
                    <TextBlock Text="{res:Loc Key=Host, Section=Comic, Format='{}{0}:'}"
                               FontSize="16" Margin="0,0,0,5" HorizontalAlignment="Left"/>
                    <TextBox IsReadOnly="True" FontSize="16" TextWrapping="NoWrap" Width="150"
                             Text="{Binding Comic.URL, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource HostConverter}}"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Vertical" Margin="10">
                    <TextBlock Text="{res:Loc Key=Author, Section=Comic, Format='{}{0}:'}" 
                               FontSize="16" Margin="0,0,0,5" HorizontalAlignment="Left" Width="150"/>
                    <TextBox FontSize="16" TextWrapping="NoWrap"
                      Text="{Binding Comic.Author, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="10">
                    <TextBlock Text="{res:Loc Key=PackageName, Section=Comic, Format='{}{0}:'}" 
                               FontSize="16" Margin="0,0,0,5" HorizontalAlignment="Left"/>
                    <TextBox FontSize="16" TextWrapping="NoWrap" Width="300"
                             Text="{Binding Comic.PackageName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="10">
                    <TextBlock Text="{res:Loc Key=Filename, Section=Comic, Format='{}{0}:'}"
                               FontSize="16" Margin="0,0,0,5"/>
                    <TextBox FontSize="16" TextWrapping="NoWrap" Width="200"
                             Text="{Binding Comic.Filename, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="10">
                    <TextBlock Text="{res:Loc Key=Pages, Section=Comic, Format='{}{0}:'}"
                               FontSize="16" Margin="0,0,0,5"
                               HorizontalAlignment="Left"/>
                    <TextBox FontSize="16" TextWrapping="NoWrap" Width="50"
                             HorizontalAlignment="Left"
                             Text="{Binding Comic.NumberPages, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="10,0,10,0">
                <TextBlock Text="{res:Loc Key=Path, Section=Comic, Format='{}{0}:'}" FontSize="16" Margin="0,0,0,5"/>
                <TextBox FontSize="16" TextWrapping="NoWrap"
                         Text="{Binding Comic.Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Vertical" Margin="10">
                    <TextBlock Text="{Binding EnableState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               FontSize="16" Margin="0,0,0,5"/>
                    <CheckBox IsChecked="{Binding Comic.Enabled, Mode=TwoWay}" HorizontalAlignment="Center"
                              Checked="CheckBox_Checked" Unchecked="CheckBox_Unchecked"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="10">
                    <TextBlock Text="{res:Loc Key=Priority, Section=Comic, Format='{}{0}:'}" FontSize="16" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Priorities}" 
                              SelectedItem="{Binding Comic.Priority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumConverter}}"
                                           FontSize="16"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
