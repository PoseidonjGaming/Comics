<Window x:Class="DownloadComics.windows.Settings.CredentialsSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DownloadComics.windows.Settings"
        xmlns:res="clr-namespace:DownloadComics.Extension"
        mc:Ignorable="d" 
        Title="{res:Loc Key=Title, Section=SettingsJDownloader}" 
        Height="300" Width="400" WindowStartupLocation="CenterOwner"
        DataContext="{Binding ViewModel, RelativeSource={RelativeSource Self}}" Closed="Window_Closed">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Vertical" Margin="10">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="{res:Loc Key=Mail, Format='{}{0}:', Section=SettingsCredentialsPage}"
                        VerticalAlignment="Center" FontSize="16" Margin="0,0,0,5"/>
                <TextBox HorizontalAlignment="Stretch"
                      FontSize="16" TextWrapping="NoWrap"
                      Text="{Binding Credentials.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <TextBlock Text="{res:Loc Key=Password, Section=SettingsCredentialsPage, Format='{}{0}:'}"
                        VerticalAlignment="Center" FontSize="16" Margin="0,0,0,5"/>
                <PasswordBox x:Name="passwordTXT" HorizontalAlignment="Stretch" FontSize="16" PasswordChanged="PasswordTXT_PasswordChanged"/>

            </StackPanel>
            <StackPanel Orientation="Vertical"  Grid.Row="1" Margin="0,10,0,0">
                <TextBlock Text="{res:Loc Key=Device, Section=SettingsCredentialsPage, Format='{}{0}:'}"
                        VerticalAlignment="Center" FontSize="16" Margin="0,0,0,5"/>
                <TextBox HorizontalAlignment="Stretch" FontSize="16" TextWrapping="NoWrap"
                      Text="{Binding Credentials.Device, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,10,0,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Button Content="{res:Loc Key=TestConnectionBTN, Section=SettingsCredentialsPage}"
                         FontSize="16" Padding="5,0,5,0"
                         Command="{Binding TestConnectionCommand}"
                         CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
                <TextBlock Name="connectionLBL" Text="{Binding ConnectionLabel, Mode=TwoWay}"
                        FontSize="16"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
