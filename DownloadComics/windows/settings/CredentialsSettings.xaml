<Window x:Class="DownloadComics.windows.settings.CredentialsSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DownloadComics.windows.settings"
        xmlns:res="clr-namespace:DownloadComics.resources"
        mc:Ignorable="d"
        Title="{res:Loc CredentialsSettings_Title}" Height="300" Width="240" WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Vertical" Margin="10">
            <StackPanel Orientation="Vertical">
                <Label Content="Email :" VerticalAlignment="Center" Target="{Binding ElementName=emailTXT}" FontSize="16" />
                <TextBox Name="emailTXT" Width="Auto" HorizontalAlignment="Stretch" Height="30" FontSize="16" TextWrapping="NoWrap"
                         VerticalAlignment="Top" VerticalContentAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" >
                <Label Content="{res:Loc Key=CredentialsSettings_Password_Label,Format={}{0}:}" VerticalAlignment="Center" Target="{Binding ElementName=passwordTXT}" FontSize="16" />
                <PasswordBox Name="passwordTXT" Width="Auto" HorizontalAlignment="Stretch" Height="30" FontSize="16"
                         VerticalAlignment="Top" VerticalContentAlignment="Center"/>

            </StackPanel>
            <StackPanel Orientation="Vertical"  Grid.Row="1">
                <Label Content="{res:Loc Key=CredentialSettings_Device_Name_Label,Format={}{0}:}" VerticalAlignment="Center" Target="{Binding ElementName=deviceNameTXT}" FontSize="16" />
                <TextBox Name="deviceNameTXT" Width="Auto" HorizontalAlignment="Stretch" Height="30" FontSize="16" TextWrapping="NoWrap"
                         VerticalAlignment="Top" VerticalContentAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,10,0,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Button Name="connectionTestBTN" Content="{res:Loc CredentialsSettings_Connection_Test_Button}" FontSize="16" Margin="0,0,10,0" Padding="10,0,10,0" Click="ConnectionTestBTN_Click"/>
                    <Button Name="saveCredentialsBTN" Content="{res:Loc CredentialsSettings_Save_Button}" FontSize="16" Margin="0,0,10,0" Padding="10,0,10,0" Click="SaveCredentialsBTN_Click" />
                </StackPanel>
                <Label Name="connectionLBL" FontSize="16"/>
            </StackPanel>

        </StackPanel>

    </Grid>
</Window>
