<Window x:Class="DownloadComics.windows.settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:enum="clr-namespace:DownloadComics.models"
        xmlns:res="clr-namespace:DownloadComics.resources"
        xmlns:conv="clr-namespace:DownloadComics.resources.converters"
        mc:Ignorable="d"       
        Title="DefaultComics" Height="520" Width="1270" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded"
        ResizeMode="NoResize">

    <Window.Resources>
        <ObjectDataProvider x:Key="EnumDataSource"
                    ObjectType="{x:Type enum:Priority}"
                    MethodName="GetValues">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enum:Priority" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <conv:EnumConverter x:Key="EnumConverter"/>
        <conv:StaticConverter x:Key="StaticConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="38*"/>
            <ColumnDefinition Width="89*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,10,10,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Vertical" Margin="0,0,50,0">
                    <Label Content="URL:" FontSize="16"/>
                    <TextBox Name="dUrlTXT" FontSize="16" TextWrapping="NoWrap" 
                             VerticalContentAlignment="Center" Width="500"/>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label Content="{res:Loc Key=Comic_Host_Label,Format={}{0}:}" FontSize="16"/>
                    <TextBox Name="hostTXT" FontSize="16" Width="150" TextWrapping="NoWrap"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Vertical">
                    <Label Content="{res:Loc Key=Comic_Author_Label,Format={}{0}:}" FontSize="16"/>
                    <TextBox Name="dAuthorTXT" FontSize="16" Width="150" TextWrapping="NoWrap"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="40,0,40,0">
                    <Label Content="{res:Loc Key=Comic_Package_Name_Label,Format={}{0}:}" FontSize="16"/>
                    <TextBox Name="pkgNameTXT" FontSize="16" Width="300" VerticalContentAlignment="Center" TextWrapping="NoWrap"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                    <Label Content="{res:Loc Key=Comic_Filename_Label,Format={}{0}:}" FontSize="16"/>
                    <TextBox Name="filenameTXT" FontSize="16" Width="200" TextWrapping="NoWrap" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label Content="{res:Loc Key=Settings_Extension_Label,Format={}{0}:}" FontSize="16"/>
                    <TextBox Name="extansionTXT" FontSize="16"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Vertical">
                <Label Content="{res:Loc Key=Comic_Path_Label,Format={}{0}:}" FontSize="16"/>
                <TextBox Name="pathTXT" FontSize="16"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                    <Label Content="{res:Loc Key=Comic_Number_Pages_Label,Format={}{0}:}" FontSize="16" HorizontalAlignment="Left"/>
                    <TextBox Name="pagesTXT" FontSize="16" HorizontalAlignment="Stretch"/>
                </StackPanel>

            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Vertical" Margin="10" VerticalAlignment="Center">
                    <Label Content="{res:Loc Key=Comic_Enabled_Label,Format={}{0}:}" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <CheckBox Name="enabledCB" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
                    <Label Content="{res:Loc Key=Comic_Priority_Label,Format={}{0}:}" FontSize="16" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                    <ComboBox Name="priorityCombo" ItemsSource="{Binding Source={StaticResource EnumDataSource}, Mode=OneWay}" FontSize="16"
                              VerticalContentAlignment="Center" SelectedIndex="3">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Name="updataBTN" Click="UpdateBTN_Click" Content="{res:Loc Common_Update_Button}"
                        FontSize="16" Padding="10,0,10,0" Margin="0,0,10,0"/>
            </StackPanel>
        </StackPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="75*"/>
                <RowDefinition Height="359*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Height="80">
                <StackPanel Orientation="Horizontal">
                    <Label Content="{res:Loc Key=Settings_Host_Label,Format={}{0}:}" VerticalAlignment="Center" FontSize="16"/>
                    <TextBox Name="itemTXT" Height="30" FontSize="16" Width="130" VerticalContentAlignment="Center"/>

                    <Button Name="addBtn" Height="30" FontSize="16" Click="AddBtn_Click" 
                            Content="{res:Loc Settings_Add_Host_Button}" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Margin="10,0,0,0" Padding="10,0,10,0"/>
                    <Button Name="removeBtn" Height="30" FontSize="16" Click="RemoveBtn_Click"
                            Content="{res:Loc Settings_Remove_Host_Button}" Margin="10,0,0,0" Padding="10,0,10,0"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <ComboBox Name="settingCB" Margin="10,10,10,0" Width="200" FontSize="16" HorizontalAlignment="Left"
                          SelectionChanged="SettingCB_SelectionChanged" SelectedIndex="0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding OptionName, Converter={StaticResource StaticConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <ListView Name="hostList" Grid.Row="1" Margin="10,10,10,10" Height="340" />
            </StackPanel>

        </Grid>
    </Grid>
</Window>
