<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ModernDownladComics.Pages.AddPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernDownladComics.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:src="using:ComicsLib.Models" 
    xmlns:view="using:ComicsInfraLib.Models.Views" 
    xmlns:conv="using:ModernDownloadComics.Converters"
    xmlns:res="using:ModernDownladComics"
    mc:Ignorable="d" DataContext="{x:Bind ViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Vertical"
                    HorizontalAlignment="Center" VerticalAlignment="Top">
            <StackPanel Orientation="Vertical" Margin="10">
                <TextBlock Text="URL:" FontSize="16" Margin="0,0,0,5"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBox x:Name="urlTXT" FontSize="16"
                         TextWrapping="NoWrap" Width="615"
                         Text="{Binding Comic.BaseURL, Mode=TwoWay}"
                         HorizontalAlignment="Left" VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="10">
                    <TextBlock Text="{res:Loc Key=Author, Format='{}{0}:', Section=Comic}" FontSize="16" Margin="0,0,0,5"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="authorTXT" FontSize="16" 
                             Text="{Binding Comic.Author, Mode=TwoWay}"
                             TextWrapping="NoWrap" Width="200"
                             HorizontalAlignment="Left" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="10">
                    <TextBlock Text="{res:Loc Key=PackageName, Format='{}{0}:', Section=Comic}" FontSize="16" Margin="0,0,0,5" 
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" x:Name="nameTXT" FontSize="16" 
                             Text="{Binding Comic.PackageName, Mode=TwoWay}"
                             TextWrapping="NoWrap" Width="300"
                             HorizontalAlignment="Left" VerticalContentAlignment="Center" />
                </StackPanel>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10">
                    <TextBlock Text="{res:Loc Key=Pages, Format='{}{0}:', Section=Comic}" FontSize="16" Margin="0,0,0,5"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="pageTXT" FontSize="16" TextWrapping="NoWrap" Width="75"
                             Text="{Binding Comic.NumberPages, Mode=TwoWay}"
                             HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>


            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="addComicBTN" Content="{res:Loc Key=AddBTN, Section=AddPage}" Margin="10"
                        Background="{StaticResource AddButton}" 
                        Command="{Binding AddComicCommand}"
                        CommandParameter="{x:Bind XamlRoot}"/>

                <Button x:Name="searchComicBTN" Content="{res:Loc Key=SearchBTN, Section=AddPage}" Margin="10" 
                        Background="{StaticResource StandardButton}"
                        Command="{Binding SearchComicCommand}"
                        CommandParameter="{x:Bind XamlRoot}"/>
                <Button x:Name="clearBTN" Content="{res:Loc Key=ClearBTN, Section=AddPage}" Margin="10"
                        Background="{StaticResource ClearButton}"
                        Command="{Binding ClearComicCommand}"/>

                <Button x:Name="deleteBTN" Content="{res:Loc Key=DeleteBTN, Section=AddPage}" FontSize="16" Margin="10"
                        Background="{StaticResource DeleteButton}"
                        Command="{Binding DelecteSelectComicCommand}"/>
            </StackPanel>
        </StackPanel>

        <ListView Grid.Column="1" Margin="10" x:Name="comicLST"
                  ItemsSource="{Binding Comics, Mode=TwoWay}"
                  DisplayMemberPath="PackageName"
                  SelectedItem="{Binding SelectedComic, Mode=TwoWay}"/>
    </Grid>
</Page>
