<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ModernDownladComics.Pages.ArchivePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernDownladComics.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" DataContext="{Binding RelativeSource={RelativeSource Self}}"
    Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="10">
            <Button x:Name="searchBTN" Content="Search" FontSize="16" Click="SearchBTN_Click"/>
            <Button x:Name="restoreBTN" Content="Restore" FontSize="16" Click="RestoreBTN_Click"
                     Margin="10,0,10,0"/>
            <Button x:Name="deleteBTN" Content="Delete" FontSize="16" Click="DeleteBTN_Click"/>
        </StackPanel>

        <TreeView x:Name="folderTree" Grid.Row="1" Margin="10" CanDrag="False"
                  ItemsSource="{x:Bind Items, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                  SelectedItem="{x:Bind SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="local:TreeItem">
                    <TreeViewItem ItemsSource="{x:Bind Children}" Content="{x:Bind Name}"/>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</Page>
