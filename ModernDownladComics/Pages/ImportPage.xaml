<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ModernDownladComics.Pages.ImportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernDownladComics.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vw="using:ComicsInfraLib.Models.Views"
    d:DataContext="{d:DesignInstance Type=vw:ImportPageViewModel}"
    mc:Ignorable="d" Loaded="Page_Loaded">

    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="177*"/>
            <RowDefinition Height="40*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="49*"/>
            <ColumnDefinition Width="250*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <ComboBox Margin="10" FontSize="16" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" ItemsSource="{Binding Files, Mode=TwoWay}"
                      SelectedItem="{Binding SelectedFile, Mode=TwoWay}"/>
            <ListView Grid.Row="1" x:Name="urlLST" Margin="10" 
                      ItemsSource="{Binding URLS, Mode=TwoWay}"
                      SelectedItem="{Binding Comic.BaseURL, Mode=TwoWay}"/>
        </Grid>

        <WebView2 x:Name="browser" Grid.Column="1" Margin="10" 
                  Source="{Binding Comic.BaseURL, Mode=TwoWay}"/>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1"
                    VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <StackPanel Margin="10" VerticalAlignment="Center">
                <TextBlock Text="URL:" FontSize="16" Padding="0,0,0,5"/>
                <TextBox Text="{Binding Comic.BaseURL}" Width="300" Height="30" TextWrapping="NoWrap" FontSize="16" IsReadOnly="True"/>
            </StackPanel>
            <StackPanel Margin="10">
                <TextBlock Text="Author:" FontSize="16" Padding="0,0,0,5"/>
                <TextBox Text="{Binding Comic.Author, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="150" Height="30" TextWrapping="NoWrap" FontSize="16"/>
            </StackPanel>
            <StackPanel Margin="10">
                <TextBlock Text="Name:" FontSize="16" Padding="0,0,0,5"/>
                <TextBox Text="{Binding Comic.PackageName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="150" Height="30" TextWrapping="NoWrap" FontSize="16"/>
            </StackPanel>
            <StackPanel Margin="10">
                <TextBlock Text="Name:" FontSize="16" Padding="0,0,0,5"/>
                <TextBox Text="{Binding Comic.NumberPages, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="75" Height="30" TextWrapping="NoWrap" FontSize="16"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10,10,10,12" VerticalAlignment="Bottom">
                <Button x:Name="addBTN" Content="Add Link" Margin="10,0,10,0" Padding="10,0,10,0"
                        Height="30" FontSize="16" Background="{StaticResource AddButton}"
                       Command="{Binding AddComicCommand}"/>
                <Button x:Name="searchBTN" Content="Search Link" 
                        Margin="10,0,10,0" Padding="10,0,10,0"
                        Height="30" FontSize="16"
                        Background="{StaticResource StandardButton}" 
                        Command="{Binding SearchComicCommand}"/>
                <Button x:Name="clearBTN" Content="Clear Link"
                        Margin="10,0,0,0" Padding="10,0,10,0"
                        Height="30" FontSize="16" 
                        Background="{StaticResource ClearButton}" 
                         Command="{Binding ResetComicCommand}"/>
            </StackPanel>
            
        </StackPanel>
    </Grid>
</Page>
