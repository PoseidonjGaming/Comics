<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ModernDownladComics.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernDownladComics.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:ModernDownloadComics.Converters"
    xmlns:src="using:ComicsLib.Models"
    xmlns:vw="using:ComicsInfraLib.Models.Views"
    xmlns:res="using:ModernDownladComics"
    mc:Ignorable="d" DataContext="{x:Bind ViewModel}">

    <Page.Resources>
        <conv:HostConverter x:Key="HostConverter"/>
        <conv:EnumConverter x:Key="EnumConverter"/>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="600"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="10,10,0,10" FontSize="16"
                     TextChanged="FilterTXT_TextChanged"/>
            <ComboBox Grid.Column="1" Margin="10" HorizontalAlignment="Stretch"
                      ItemsSource="{Binding Hosts}"
                      SelectedItem="{Binding SelectedHost, Mode=TwoWay}"
                      SelectionChanged="Hosts_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource HostConverter}}"
                                   FontSize="16"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <ListView Grid.Row="1" Grid.ColumnSpan="2" x:Name="comicsLST" 
                      Margin="10" ItemsSource="{Binding Comics, Mode=TwoWay}"
                      SelectedItem="{Binding SelectedComic, Mode=TwoWay}"
                      DisplayMemberPath="PackageName"/>
        </Grid>
        

        <StackPanel Grid.Column="1" Orientation="Vertical" Margin="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Vertical" Margin="0,0,20,0">
                    <TextBlock Text="URL:" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SelectedComic.URL, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Width="750"
                             HorizontalAlignment="Left" VerticalAlignment="Top"/>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{res:Loc Key=Host, Format='{}{0}:', Section=Comic}" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox FontSize="16" Width="150" TextWrapping="NoWrap"
                             Text="{Binding SelectedComic.URL, Converter={StaticResource HostConverter}}"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,10,0,0">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{res:Loc Key=Author, Format='{}{0}:', Section=Comic}" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SelectedComic.Author, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="150" TextWrapping="NoWrap"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="20,0,20,0">
                    <TextBlock Text="{res:Loc Key=PackageName, Format='{}{0}:', Section=Comic}" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SelectedComic.PackageName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Width="300" TextWrapping="NoWrap"/>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{res:Loc Key=Filename, Format='{}{0}:', Section=Comic}" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SelectedComic.Filename, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Width="250" TextWrapping="NoWrap"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <TextBlock Text="{res:Loc Key=Path, Format='{}{0}:', Section=Comic}" FontSize="16" Margin="0,0,0,5"/>
                <TextBox Text="{Binding SelectedComic.Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="16" Width="700" TextWrapping="NoWrap" HorizontalAlignment="Left"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{res:Loc Key=Pages, Format='{}{0}:', Section=Comic}" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SelectedComic.NumberPages, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Width="75" TextWrapping="NoWrap" HorizontalAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="20,0,20,0">
                    <TextBlock Text="{res:Loc Key=Enable, Format='{}{0}:', Section=Comic}" FontSize="16" Margin="0,0,0,5"/>
                    <CheckBox
                        IsChecked="{Binding SelectedComic.Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="{res:Loc Key=Priority, Format='{}{0}:', Section=Comic}" FontSize="16" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Priorities}"
                              SelectedItem="{Binding SelectedComic.Priority, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumConverter}}" FontSize="16"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button x:Name="changeSourceBTN" Content="{res:Loc Key=ChangeSourceBTN, Section=MainPage}"
                        FontSize="16" Padding="5" Command="{Binding ChangeSourceCommand}"/>
                <Button x:Name="unselectBTN" Content="{res:Loc Key=UnselectBTN, Section=MainPage}"
                        FontSize="16" Margin="20,0,20,0" Padding="5" Command="{Binding UnselectCommand}"/>
                <Button Content="{res:Loc Key=DeleteBTN, Section=MainPage}" Padding="5" FontSize="16"
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
