<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ModernDownladComics.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernDownladComics"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:res="using:ModernDownladComics"
    mc:Ignorable="d"
    Title="ModernDownladComics" Closed="Window_Closed">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView x:Name="navView" PaneDisplayMode="LeftCompact"
                        SelectionChanged="NavigationView_SelectionChanged" 
                        IsSettingsVisible="False">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="{res:Loc Key=Home, Section=MainWindow}" Tag="home" Icon="Home"/>
                <NavigationViewItem Content="{res:Loc Key=Send, Section=MainWindow}" Tag="send" Icon="Upload"/>

                <NavigationViewItem Content="{res:Loc Key=Add, Section=MainWindow}" SelectsOnInvoked="False" Icon="Add">
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="{res:Loc Key=AddLink, Section=MainWindow}" Tag="add" Icon="Add"/>
                        <NavigationViewItem Content="{res:Loc Key=ImportLinks, Section=MainWindow}" Tag="import" Icon="Import"/>
                    </NavigationViewItem.MenuItems>

                </NavigationViewItem>
                <NavigationViewItem Content="{res:Loc Key=Archive, Section=MainWindow}" Tag="archive" Icon="Folder"/>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="{res:Loc Key=Settings, Section=MainWindow}"
                                    Tag="settings" Icon="Setting"/>
            </NavigationView.FooterMenuItems>
            <Frame x:Name="frame"/>
        </NavigationView>


        <Rectangle x:Name="dimmingOverlay"
                   Fill="#80000000"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"/>
    </Grid>
</Window>

