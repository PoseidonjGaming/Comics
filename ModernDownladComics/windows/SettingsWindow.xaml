<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ModernDownladComics.windows.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernDownladComics.windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SettingsWindow" Closed="Window_Closed">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <NavigationView x:Name="navView" PaneDisplayMode="Left" 
                    SelectionChanged="NavigationView_SelectionChangedAsync"
                    IsSettingsVisible="False" IsPaneOpen="True" IsBackButtonVisible="Collapsed"
                    IsPaneToggleButtonVisible="False" OpenPaneLength="250">
        
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Comic" Icon="Library"/>
            <NavigationViewItem Content="{x:Bind Loc['Hosts']}"
                                SelectsOnInvoked="False" Icon="Globe">
                <NavigationViewItem.MenuItems>
                    <NavigationViewItem Content="{x:Bind Loc['SearchHosts']}" 
                                        Tag="search" Icon="Zoom"/>
                    <NavigationViewItem Content="{x:Bind Loc['ConfirmHosts']}"
                                        Tag="confirm" Icon="Play"/>
                    <NavigationViewItem Content="{x:Bind Loc['ExcludedHosts']}" 
                                        Tag="excluded" Icon="Clear"/>
                </NavigationViewItem.MenuItems>
            </NavigationViewItem>
            <NavigationViewItem Content="{x:Bind Loc['Paths']}" Tag="path" Icon="Save"/>
            <NavigationViewItem Content="{x:Bind Loc['Credentials']}" 
                                Tag="credentials" Icon="Permissions"/>
        </NavigationView.MenuItems>
        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="{x:Bind Loc['ImportSettings']}" 
                                Tag="import_settings" Icon="OpenFile"/>
            <NavigationViewItem Content="{x:Bind Loc['ExportSettings']}" 
                                Tag="export_settings" Icon="SaveLocal"/>
        </NavigationView.FooterMenuItems>
        <Frame x:Name="settingsFrame"/>
    </NavigationView>
</Window>
